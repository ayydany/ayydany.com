{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Hexo: Serve",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/hexo/bin/hexo",
      "args": ["serve"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Gulp: Dev",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/gulp/bin/gulp.js",
      "args": ["dev"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
